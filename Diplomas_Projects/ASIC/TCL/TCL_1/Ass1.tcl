puts "****Bitwise Operations****"
#1st req
set a 20
#2nd req
set b 5
#3rd req 
set c 9
#4th req
set var0 [expr $a & $c]
#5th req
set var1 [expr $a | $b]
#6th req
set var2 [expr $a ^ $a]
#7th req,8th req , 9th req
puts " the value of a & c is :$var0"
puts " the value of a | b is :$var1"
puts "the value of a ^ a is :$var2"
