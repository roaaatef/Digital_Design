module DSP_tb();
reg [17:0] A;
reg [17:0] B;
reg [47:0] C;
reg [17:0] D;
reg CARRYIN;
wire [35:0] M;
wire [47:0] P;
wire CARRYOUT;
wire CARRYOUTF;
reg CLK;
reg [7:0]OPMODE;
reg CEA,CEB,CEC,CECARRYIN,CED,CEM,CEOPMODE,CEP;
reg RSTA,RSTB,RSTC,RSTCARRYIN,RSTD,RSTM,RSTOPMODE,RSTP;
reg[47:0] PCIN;
wire [47:0] PCOUT;
wire [17:0] BCOUT;
reg [17:0] BCIN;
///////////////////////////////////////////////////////////////////////////
parameter A0REG=0;
parameter A1REG=1;
parameter B0REG=0;
parameter B1REG=1;
parameter CREG=1;
parameter DREG=1;
parameter MREG=1;
parameter PREG=1;
parameter CARRYINREG=1;
parameter CARRYOUTREG=1;
parameter OPMODEREG=1;
parameter CARRYINSEL="OPMODE5";
parameter B_INPUT="DIRECT";
parameter RSTTYPE="SYNC";
/////////////////////////////////////////////////////////
reg [17:0]W1;
reg [47:0] W2,W3;
reg [48:0] W4;
 DSP  dsp (
 A,
 B,
 C,
 D,
 CARRYIN,
  M,
 P,
 CARRYOUT,
 CARRYOUTF,
 CLK,
 OPMODE,
 CEA,CEB,CEC,CECARRYIN,CED,CEM,CEOPMODE,CEP,
 RSTA,RSTB,RSTC,RSTCARRYIN,RSTD,RSTM,RSTOPMODE,RSTP,
  PCIN,
 PCOUT,
 BCOUT,
 BCIN
	);
 /////////////////////////////
 initial begin
 	CLK=0;
 	forever
 	#1 CLK=~CLK;
 end
 /////////////////////////////////
 integer i;
 initial begin
 //rst test
RSTA=1; RSTB=1; RSTC=1; RSTD=1;
RSTOPMODE=1; RSTCARRYIN=1;
RSTP=1; RSTM=1; 
///////////////////////////////////
A=0; B=0; C=0; D=0; 
BCIN=0;  PCIN=0; 
CARRYIN=0;  OPMODE=0;
CEA=0;CEB=0;CEC=0;CECARRYIN=0;CED=0;CEM=0;CEOPMODE=0;CEP=0;
repeat (8) begin
	@(negedge CLK);
end
//////////////////////////////////
RSTA=0; RSTB=0; RSTC=0; RSTD=0;
RSTOPMODE=0; RSTCARRYIN=0;
RSTP=0; RSTM=0; 
CEA=1;CEB=1;CEC=1;CECARRYIN=1;CED=1;CEM=1;CEOPMODE=1;CEP=1;
// test first adder (add), second adder (add) // 12
A=18'd1; B=18'd1 ; C= 48'd1; D=18'd1;
PCIN=48'd10;
OPMODE[6]=1'b0;
OPMODE[4]=1'b1;
OPMODE[1:0] =2'b01;
OPMODE[3:2]=2'b01;
OPMODE[7]=1'b0;
OPMODE[5]=1'b0;
W1=B+D;
W2=W1*A;
W3=W2+PCIN;
repeat(4) begin
	@(negedge CLK);
end
if (P!=W3)
	begin
		$display ("error");
		$display("P=%d,W3=%d",P,W3);
		$stop;
	end
	else begin
$display("success");
end
/////////////////////////////////////////////
//test first adder (sub) , second adder (add) //14
A=18'd1; B=18'd1 ; C= 48'd1; D=18'd5;
PCIN=48'd10;
OPMODE[6]=1'b1;
OPMODE[4]=1'b1;
OPMODE[1:0] =2'b01;
OPMODE[3:2]=2'b01;
OPMODE[7]=1'b0;
OPMODE[5]=1'b0;
W1=D-B;
W2=W1*A;
W3=W2+PCIN;
repeat(4) begin
	@(negedge CLK);
end
if (P!=W3)
	begin
		$display ("error");
		$display("P=%d,W3=%d",P,W3);
		$stop;
	end
	else begin
$display("success");
end
////////////////////////////////////////////
//test second adder (sub) , first adder (add) //8
A=18'd1; B=18'd1 ; C= 48'd1; D=18'd1;
PCIN=48'd10;
OPMODE[6]=1'b0;
OPMODE[4]=1'b1;
OPMODE[1:0] =2'b01;
OPMODE[3:2]=2'b01;
OPMODE[7]=1'b1;
OPMODE[5]=1'b0;
W1=D+B;
W2=W1*A;
W3=PCIN-W2;
repeat(4) begin
	@(negedge CLK);
end
if (P!=W3)
	begin
		$display ("error");
		$display("P=%d,W3=%d",P,W3);
		$stop;
	end
	else begin
$display("success");
end
/////////////////////////////////
//test second adder (sub) , first adder (sub) //1
A=18'd1; B=18'd1 ; C= 48'd1; D=18'd10;
PCIN=48'd10;
OPMODE[6]=1'b1;
OPMODE[4]=1'b1;
OPMODE[1:0] =2'b01;
OPMODE[3:2]=2'b01;
OPMODE[7]=1'b1;
OPMODE[5]=1'b0;
W1=D-B;
W2=W1*A;
W3=PCIN-W2;
repeat(4) begin
	@(negedge CLK);
end
if (P!=W3)
	begin
		$display ("error");
		$display("P=%d,W3=%d",P,W3);
		$stop;
	end
	else begin
$display("success");
end
//////////////////////////////////////////////
//test second adder (add) , first adder (add),opmode_4_mux=B  // ((B*A)+PCIN)=11
A=18'd1; B=18'd1 ; C= 48'd1; D=18'd10;
PCIN=48'd10;
OPMODE[6]=1'b0;
OPMODE[4]=1'b0;
OPMODE[1:0] =2'b01;
OPMODE[3:2]=2'b01;
OPMODE[7]=1'b0;
OPMODE[5]=1'b0;
W2=B*A;
W3=W2+PCIN;
repeat(4) begin
	@(negedge CLK);
end
if (P!=W3)
	begin
		$display ("error");
		$display("P=%d,W3=%d",P,W3);
		$stop;
	end
	else begin
$display("success");
end
//////////////////////////////////////////////////////
//test second adder (add) , first adder (add) , cin  // ((D+B)*A)+PCIN+CIN=22;
A=18'd1; B=18'd1 ; C= 48'd1; D=18'd10;
PCIN=48'd10;
OPMODE[6]=1'b0;
OPMODE[4]=1'b1;
OPMODE[1:0] =2'b01;
OPMODE[3:2]=2'b01;
OPMODE[7]=1'b0;
OPMODE[5]=1'b1;
W1=D+B;
W2=W1*A;
W3=W2+PCIN;
W4=W3+OPMODE[5];
repeat(4) begin
	@(negedge CLK);
end
if (P!=W4)
	begin
		$display ("error");
		$display("P=%d,W3=%d",P,W3);
		$stop;
	end
	else begin
$display("success");
end
//////////////////////////////////////////////////
//test second adder (add) , first adder (add) , p as input  // P+PCIN=;
A=18'd1; B=18'd1 ; C= 48'd1; D=18'd10;
PCIN=48'd10;
OPMODE[6]=1'b0;
OPMODE[4]=1'b1;
OPMODE[1:0] =2'b10;
OPMODE[3:2]=2'b01;
OPMODE[7]=1'b0;
OPMODE[5]=1'b0;

repeat(4) begin
W3=P+PCIN;
	@(negedge CLK);

end
if (P!=W3)
	begin
		$display ("error");
		$display("P=%d,W3=%d",P,W3);
		$stop;
	end
	else begin
$display("success");
end
//////////////////////////////////////////////////////////////////////
//test second adder (add) , first adder (add) , select is 0 in mux x and z  
A=18'd1; B=18'd1 ; C= 48'd1; D=18'd10;
PCIN=48'd10;
OPMODE[6]=1'b0;
OPMODE[4]=1'b1;
OPMODE[1:0] =2'b00;
OPMODE[3:2]=2'b00;
OPMODE[7]=1'b0;
OPMODE[5]=1'b0;

repeat(4) begin
	@(negedge CLK);
end
if (P!=0);
		begin
		$display ("error");
		$display("P=%d,W3=%d",P,W3);
		$stop;
	end
	else begin
$display("success");
end
///////////////////////////////
//test second adder (add) , first adder (add) , select is  11 in mux z
//((D+B)*A)+C
A=18'd1; B=18'd1 ; C= 48'd1; D=18'd10;
PCIN=48'd10;
OPMODE[6]=1'b0;
OPMODE[4]=1'b1;
OPMODE[1:0] =2'b01;
OPMODE[3:2]=2'b11;
OPMODE[7]=1'b0;
OPMODE[5]=1'b0;
W1=D+B;
W2=W1*A;
W3=W2+C;
repeat(4) begin
	@(negedge CLK);
end
if (P!=W3)
	begin
		$display ("error");
		$display("P=%d,W3=%d",P,W3);
		$stop;
	end
	else begin
$display("success");
end
//////////////////////////////////////////////////////////
// X sel = 3 [D:A:B] && Z sel = 0 [0]  
	A = 18'd1; B = 18'd1 ; C = 48'd1; D = 18'd1;
	OPMODE[6] = 1'b0;
	OPMODE[4] = 1'b0;
	OPMODE[1:0] = 2'b11;
	OPMODE[3:2] = 1'b0;
	OPMODE[7] = 1'b0; // Add
	OPMODE[5] = 1'b0;

	repeat(4) begin
	@(negedge CLK);
end
if (P!=({D[11:0],A[17:0],B[17:0]}+PCIN))
	begin
		$display ("error");
		$stop;
	end
$stop;
 end
endmodule
